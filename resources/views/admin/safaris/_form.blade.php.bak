{{-- ═══════════════════════════════════════════════════════
     Alpine.js Component
     ═══════════════════════════════════════════════════════ --}}
<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('safariForm', () => ({
        selectedCountry: '',
        loadingDestinations: false,
        allDestinations: @json($destinationsJson),
        selectedDestinationIds: @json(array_map('intval', $selectedDestinations)),

        get filteredDestinations() {
            if (!this.selectedCountry) return this.allDestinations;
            const countryId = parseInt(this.selectedCountry);
            return this.allDestinations.filter(d => d.country_id === countryId);
        },

        // Itinerary days — initialised from server data
        days: @json($itineraryJson),
        nextId: {{ count($itineraryItems) }},

        addDay() {
            // Collapse others for focus, open the new one
            this.days.forEach(d => d.open = false);
            this.days.push({
                id:             this.nextId++,
                title:          '',
                description:    '',
                accommodation:  '',
                destination_id: '',
                open:           true,
            });
        },

        removeDay(idx) {
            this.days.splice(idx, 1);
        },

        moveDay(idx, direction) {
            const target = idx + direction;
            if (target < 0 || target >= this.days.length) return;
            const temp = this.days[idx];
            this.days[idx] = this.days[target];
            this.days[target] = temp;
            // Force Alpine reactivity by replacing array reference
            this.days = [...this.days];
        },

        expandAllDays() {
            this.days.forEach(d => d.open = true);
        },

        collapseAllDays() {
            this.days.forEach(d => d.open = false);
        },

        async fetchDestinations() {
            this.loadingDestinations = true;

            try {
                const url = new URL("{{ route('admin.api.destinations') }}", window.location.origin);
                if (this.selectedCountry) {
                    url.searchParams.set('country_id', this.selectedCountry);
                }

                const res  = await fetch(url, {
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await res.json();

                // Update the reactive data — Alpine re-renders both selects automatically
                if (this.selectedCountry) {
                    // Replace only destinations for this country, keep the rest
                    const countryId = parseInt(this.selectedCountry);
                    const others = this.allDestinations.filter(d => d.country_id !== countryId);
                    this.allDestinations = [...others, ...data];
                } else {
                    this.allDestinations = data;
                }
            } catch (e) {
                console.error('Failed to fetch destinations', e);
            } finally {
                this.loadingDestinations = false;
            }
        },

        syncSelectedDestinations() {
            const select = document.getElementById('destinations_select');
            if (select) {
                this.selectedDestinationIds = Array.from(select.selectedOptions).map(o => parseInt(o.value));
            }
        },
    }));
});
</script>
