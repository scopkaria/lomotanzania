                                                  class="w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-gold focus:ring-brand-gold text-sm"></textarea>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Accommodation</label>
                                        <input type="text" :name="'itinerary[' + idx + '][accommodation]'" x-model="day.accommodation"
                                               placeholder="e.g. Serengeti Serena Lodge"
                                               class="w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-gold focus:ring-brand-gold text-sm">
