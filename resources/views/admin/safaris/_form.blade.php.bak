                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Description</label>
                                        <textarea :name="'itinerary[' + idx + '][description]'" x-model="day.description" rows="3"
